<style>
  .page-header { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); border-radius:12px; padding:24px 28px; margin-bottom:24px; display:flex; align-items:center; justify-content:space-between; }
  .page-header h2 { color:#fff; font-weight:700; font-size:1.5rem; margin:0; }
  .page-header p { color:rgba(255,255,255,0.6); margin:4px 0 0; font-size:0.85rem; }
  .stat-card { border-radius:12px; padding:20px 24px; border:none; position:relative; overflow:hidden; }
  .stat-card::after { content:''; position:absolute; top:-20px; right:-20px; width:80px; height:80px; border-radius:50%; opacity:0.1; background:#fff; }
  .stat-card .stat-icon { font-size:1.8rem; opacity:0.9; margin-bottom:8px; }
  .stat-card .stat-value { font-size:2rem; font-weight:700; color:#fff; line-height:1; }
  .stat-card .stat-label { font-size:0.8rem; color:rgba(255,255,255,0.75); text-transform:uppercase; letter-spacing:0.8px; margin-top:4px; }
  .stat-total { background:linear-gradient(135deg,#667eea,#764ba2); }
  .stat-active { background:linear-gradient(135deg,#11998e,#38ef7d); }
  .stat-inactive { background:linear-gradient(135deg,#f7971e,#ffd200); }
  .main-card { border:none; border-radius:12px; box-shadow:0 2px 12px rgba(0,0,0,0.08); }
  .main-card .card-header { background:#fff; border-bottom:1px solid #f0f0f0; border-radius:12px 12px 0 0 !important; padding:16px 20px; display:flex; align-items:center; justify-content:space-between; }
  .main-card .card-header h5 { font-weight:700; color:#1a1a2e; margin:0; font-size:1rem; }
  .search-box { position:relative; width:240px; }
  .search-box input { border-radius:20px; padding-left:36px; border:1px solid #e0e0e0; font-size:0.875rem; height:36px; }
  .search-box .search-icon { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#aaa; font-size:0.8rem; }
  .btn-add { background:linear-gradient(135deg,#667eea,#764ba2); color:#fff; border:none; border-radius:8px; padding:8px 18px; font-size:0.875rem; font-weight:600; transition:all 0.2s; }
  .btn-add:hover { color:#fff; opacity:0.9; transform:translateY(-1px); box-shadow:0 4px 12px rgba(102,126,234,0.4); }
  .pro-table thead th { background:#f8f9ff; color:#555; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.6px; border:none; padding:12px 16px; }
  .pro-table tbody td { vertical-align:middle; padding:14px 16px; font-size:0.875rem; color:#444; border-color:#f5f5f5; }
  .pro-table tbody tr:hover { background:#f8f9ff; }
  .mono-text { font-family:'Courier New',monospace; font-weight:700; color:#1a1a2e; font-size:0.85rem; }
  .dev-badge { display:inline-flex; align-items:center; gap:6px; background:#f0f2ff; color:#667eea; padding:4px 10px; border-radius:6px; font-size:0.78rem; font-weight:600; }
  .status-wrap { display:flex; align-items:center; gap:8px; }
  .status-pill { font-size:0.75rem; font-weight:600; padding:3px 10px; border-radius:20px; }
  .status-pill.active { background:#e8f8f0; color:#1a9a5e; }
  .status-pill.inactive { background:#fef0f0; color:#d93025; }
  .action-btn { width:32px; height:32px; border-radius:8px; display:inline-flex; align-items:center; justify-content:center; font-size:0.8rem; transition:all 0.15s; border:none; }
  .btn-edit-r { background:#fff8e6; color:#f0a500; }
  .btn-edit-r:hover { background:#f0a500; color:#fff; }
  .btn-del-r { background:#fef0f0; color:#d93025; }
  .btn-del-r:hover { background:#d93025; color:#fff; }
  .empty-state { padding:60px 20px; text-align:center; color:#aaa; }
  .empty-state i { font-size:3rem; margin-bottom:12px; opacity:0.3; }
</style>

<section class="content-header">
  <div class="container-fluid">
    <ol class="breadcrumb" style="background:transparent; padding:0; margin:0 0 8px;">
      <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
      <li class="breadcrumb-item active">Vehicle</li>
    </ol>
  </div>
</section>

<section class="content">
  <div class="container-fluid">

    <!-- Header Banner -->
    <div class="page-header">
      <div>
        <h2><i class="fas fa-motorcycle mr-2"></i>Vehicle Management</h2>
        <p>Kelola armada kendaraan</p>
      </div>
      <a href="/vehicle/create" class="btn btn-add">
        <i class="fas fa-plus mr-1"></i> Tambah Kendaraan
      </a>
    </div>

    <!-- Stat Cards -->
    <div class="row mb-4">
      <div class="col-md-4">
        <div class="stat-card stat-total">
          <div class="stat-icon"><i class="fas fa-motorcycle"></i></div>
          <div class="stat-value"><%= data.length %></div>
          <div class="stat-label">Total Kendaraan</div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card stat-active">
          <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
          <div class="stat-value"><%= data.filter(r => r.status == 1).length %></div>
          <div class="stat-label">Active</div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card stat-inactive">
          <div class="stat-icon"><i class="fas fa-times-circle"></i></div>
          <div class="stat-value"><%= data.filter(r => r.status != 1).length %></div>
          <div class="stat-label">Inactive</div>
        </div>
      </div>
    </div>

    <!-- Table Card -->
    <div class="card main-card">
      <div class="card-header">
        <h5><i class="fas fa-list mr-2" style="color:#667eea;"></i>Daftar Kendaraan</h5>
        <div class="search-box">
          <i class="fas fa-search search-icon"></i>
          <input type="text" id="searchInput" class="form-control" placeholder="Cari kendaraan...">
        </div>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table pro-table mb-0" id="mainTable">
            <thead>
              <tr>
                <th>No</th>
                <th>Vehicle ID</th>
                <th>Police No</th>
                <th>Brand</th>
                <th>Model</th>
                <th>Year</th>
                <th>Color</th>
                <th>Fuel</th>
                <th>Status</th>
                <th class="text-center">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (data.length === 0) { %>
                <tr>
                  <td colspan="10">
                    <div class="empty-state">
                      <i class="fas fa-motorcycle d-block"></i>
                      <p>Belum ada data kendaraan</p>
                    </div>
                  </td>
                </tr>
              <% } else { %>
                <% data.forEach((row, index) => { %>
                  <tr>
                    <td><span style="color:#aaa; font-size:0.8rem;"><%= index + 1 %></span></td>
                    <td><span class="mono-text"><%= row.vehicle_id %></span></td>
                    <td>
                      <span class="dev-badge">
                        <i class="fas fa-id-badge"></i>
                        <%= row.police_number %>
                      </span>
                    </td>
                    <td><%= row.brand %></td>
                    <td><%= row.model %></td>
                    <td><%= row.assembly_year %></td>
                    <td>
                      <span style="display:inline-flex; align-items:center; gap:5px; font-size:0.83rem;">
                        <i class="fas fa-circle" style="font-size:0.6rem; color:#888;"></i>
                        <%= row.color %>
                      </span>
                    </td>
                    <td><%= row.fuel %></td>
                    <td>
                      <div class="status-wrap">
                        <div class="custom-control custom-switch mb-0">
                          <input type="checkbox" class="custom-control-input status-toggle"
                            id="status-<%= row.id %>" data-id="<%= row.id %>"
                            <%= row.status == 1 ? 'checked' : '' %>>
                          <label class="custom-control-label" for="status-<%= row.id %>"></label>
                        </div>
                        <span id="label-<%= row.id %>"
                          class="status-pill <%= row.status == 1 ? 'active' : 'inactive' %>">
                          <%= row.status == 1 ? 'Active' : 'Inactive' %>
                        </span>
                      </div>
                    </td>
                    <td class="text-center">
                      <a href="/vehicle/edit/<%= row.id %>" class="action-btn btn-edit-r" title="Edit">
                        <i class="fas fa-pen"></i>
                      </a>
                      <a href="/vehicle/delete/<%= row.id %>"
                        onclick="return confirm('Hapus kendaraan <%= row.vehicle_id %>?')"
                        class="action-btn btn-del-r ml-1" title="Hapus">
                        <i class="fas fa-trash"></i>
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  document.getElementById('searchInput').addEventListener('input', function () {
    const q = this.value.toLowerCase();
    document.querySelectorAll('#mainTable tbody tr').forEach(tr => {
      tr.style.display = tr.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  });
  document.querySelectorAll('.status-toggle').forEach(cb => {
    cb.addEventListener('change', function () {
      const id = this.getAttribute('data-id'), isChecked = this.checked ? 1 : 0;
      const label = document.getElementById('label-' + id);
      fetch('/vehicle/update-status', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({id, status:isChecked}) })
        .then(r => { if(!r.ok) throw new Error(); return r.json(); })
        .then(() => { label.className = isChecked ? 'status-pill active' : 'status-pill inactive'; label.innerText = isChecked ? 'Active' : 'Inactive'; })
        .catch(() => { alert('Gagal memperbarui status'); this.checked = !this.checked; });
    });
  });
</script>
