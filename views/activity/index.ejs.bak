<section class="content-header">
  <div class="container-fluid">
    <h1>Activities</h1>
  </div>
</section>

<section class="content mt-3">
      <div class="card">
        <div class="card-header">
          <a href="/activity/create" class="btn btn-primary btn-sm">
            <i class="fas fa-plus"></i> New Activity
          </a>

          <div class="card-tools">
            <button type="button" class="btn btn-tool" data-card-widget="collapse">
              <i class="fas fa-minus"></i>
            </button>
            <button type="button" class="btn btn-tool" data-card-widget="remove">
              <i class="fas fa-times"></i>
            </button>
          </div>
        </div>

        <div class="card-body table-responsive">
          <table id="example2" class="table table-bordered table-hover">
            <thead>
              <tr>
                <th>Activity ID</th>
                <th>Name</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Personnel</th>
                <th>Status</th>
                <th>#</th>
              </tr>
            </thead>
            <tbody>
              <% rows.forEach(row=> { %>
                <tr>
                  <td>
                    <%= row.activity_id %>
                  </td>
                  <td>
                    <%= row.activity_name %>
                  </td>
                  <td>
                    <%= row.start_date %>
                  </td>
                  <td>
                    <%= row.end_date %>
                  </td>
                  <td>
                    <%= row.personnel %>
                  </td>
                  <td>
                    <div class="custom-control custom-switch">
                      <input type="checkbox" class="custom-control-input status-toggle"
                        id="status-<%= row.id %>" data-id="<%= row.id %>" <%= row.status==1 ? 'checked' : '' %>>
                      <label class="custom-control-label" for="status-<%= row.id %>">
                        <span id="label-<%= row.id %>"
                          class="badge <%= row.status == 1 ? 'badge-success' : 'badge-danger' %>">
                          <%= row.status==1 ? 'Active' : 'Inactive' %>
                        </span>
                      </label>
                    </div>
                  </td>
                  <td width="200" class="text-center">
                    <a target="_blank" rel="noopener noreferrer" href="/activity/details/<%= row.activity_id %>"
                      class="btn btn-success btn-sm">
                      <i class="fas fa-eye"></i>
                    </a>
                    <!-- <a target="_blank" rel="noopener noreferrer" href="/maps/groups/<%= //row.activity_id %>"
                      class="btn btn-success btn-sm">
                      <i class="fas fa-map"></i>
                    </a>
                    <a href="/maps/activity/<%= //row.id %>" class="btn btn-info btn-sm">
                      <i class="fas fa-video"></i>
                    </a> -->
                    <a href="/activity/edit/<%= row.id %>" class="btn btn-warning btn-sm">
                      <i class="fas fa-edit"></i>
                    </a>

                    <a href="/activity/delete/<%= row.id %>" onclick="return confirm('Delete this Activity?')"
                      class="btn btn-danger btn-sm">
                      <i class="fas fa-trash"></i>
                    </a>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>
      </div>
</section>

<script>
  document.querySelectorAll('.status-toggle').forEach(checkbox => {
    checkbox.addEventListener('change', function () {
      const id = this.getAttribute('data-id');
      const isChecked = this.checked ? 1 : 0;
      const label = document.getElementById(`label-${id}`);

      fetch('/activity/update-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, status: isChecked })
      })
        .then(response => {
          if (!response.ok) throw new Error('Network response was not ok');
          return response.json();
        })
        .then(() => {
          label.className = isChecked ? 'badge badge-success' : 'badge badge-danger';
          label.innerText = isChecked ? 'Active' : 'Inactive';
        })
        .catch(() => {
          alert('Gagal memperbarui status');
          this.checked = !this.checked;
        });
    });
  });
</script>