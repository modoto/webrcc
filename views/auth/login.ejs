<!-- /.login-logo -->
<div class="card card-outline card-primary">
  <div class="card-header text-center">
    <a href="/" class="h1"><b>KOMANDO</b></a>
  </div>
  <div class="card-body">
    <p class="login-box-msg">Sign in to start your sessions</p>

    <form action="/loginweb" method="post">
      <div class="input-group mb-3">
        <input type="text" class="form-control" placeholder="Username" name="username" autocomplete="off" required>
        <div class="input-group-append">
          <div class="input-group-text">
            <span class="fas fa-user"></span>
          </div>
        </div>
      </div>
      <div class="input-group mb-3">
        <input type="password" id="password-field" class="form-control" placeholder="Password" name="password" value="" autocomplete="off" required>
        <div class="input-group-append">
          <div class="input-group-text" style="cursor: pointer;" id="toggle-password">
            <span class="fas fa-lock" id="eye-icon"></span>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-8">
          <!-- <div class="icheck-primary">
              <input type="checkbox" id="remember">
              <label for="remember">
                Remember Me
              </label>
            </div> -->
        </div>
        <!-- /.col -->
        <div class="col-4">
          <button type="submit" class="btn btn-primary btn-block">Sign In</button>
        </div>
        <!-- /.col -->
      </div>
    </form>

  </div>
  <!-- /.card-body -->
</div>
<!-- /.card -->

<script>
  const togglePassword = document.querySelector('#toggle-password');
  const passwordField = document.querySelector('#password-field');
  const eyeIcon = document.querySelector('#eye-icon');

  togglePassword.addEventListener('click', function () {
    // Cek tipe input saat ini
    const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
    passwordField.setAttribute('type', type);

    // Opsional: Ubah icon gembok menjadi mata saat terbuka (biar lebih keren)
    if (type === 'text') {
      eyeIcon.classList.remove('fa-lock');
      eyeIcon.classList.add('fa-eye');
    } else {
      eyeIcon.classList.remove('fa-eye');
      eyeIcon.classList.add('fa-lock');
    }
  });
</script>