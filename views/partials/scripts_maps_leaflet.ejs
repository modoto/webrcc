  function simulateGPS() {

    const data = [];

    Object.keys(dummyRoutes).forEach(id => {

      const route = dummyRoutes[id];

      //if (dummyIndex >= route.length) {
      //dummyIndex = route.length - 1; // berhenti di Indomaret
      //}

      if (dummyIndex >= route.length) {
        dummyIndex = 0; // ulang dari awal
      }

      data.push({
        id: id,
        coords: route[dummyIndex],
        popup: "Motor testing dari Permata Bank ke Indomaret"
      });

    });

    dummyIndex++;

    updateMarkers(data);

  }

