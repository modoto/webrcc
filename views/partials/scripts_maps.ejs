  // =============================
  // CUSTOM MARKER
  // =============================
  class CustomMarker extends google.maps.OverlayView {
    constructor(position, map, imageUrl, popup ) {
      super();
      this.position = new google.maps.LatLng(position.lat, position.lng);
      this.map = map;
      this.imageUrl = imageUrl;
      this.popup = popup;
      this.div = null;
      this.angle = 0;

      this.setMap(map);
    }

    onAdd() {
      this.div = document.createElement("div");
      this.div.style.position = "absolute";

      // container
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      const img = document.createElement("img");
      img.src = this.imageUrl;
      img.style.width = "45px";
      img.style.height = "66px";
      img.style.transformOrigin = "center center";
      img.style.transition = "transform 0.2s linear";

      // 🔥 LABEL
      const label = document.createElement("div");
      label.innerHTML = this.popup || "iki lho";
      label.style.position = "absolute";
      label.style.bottom = "100%";
      label.style.left = "50%";
      label.style.transform = "translateX(-50%)";
      label.style.background = "white";
      label.style.padding = "2px 6px";
      label.style.borderRadius = "6px";
      label.style.fontSize = "12px";
      label.style.whiteSpace = "nowrap";
      label.style.boxShadow = "0 2px 6px rgba(0,0,0,0.3)";

      this.img = img;

      wrapper.appendChild(img);
      wrapper.appendChild(label);
      this.div.appendChild(wrapper);

      const panes = this.getPanes();
      panes.overlayImage.appendChild(this.div);
    }

    draw() {
      const projection = this.getProjection();
      if (!projection) return; // ⛑️ WAJIB

      const pos = projection.fromLatLngToDivPixel(this.position);

      if (this.div && pos) {
        this.div.style.left = pos.x - 22 + "px";
        this.div.style.top = pos.y - 33 + "px";
      }
    }

    updatePosition(latLng) {
      this.position = new google.maps.LatLng(latLng.lat, latLng.lng);

      if (this.getProjection()) {
        this.draw();
      }
    }

    setRotation(angle) {
      this.angle = angle;
      if (this.img) {
        this.img.style.transform = `rotate(${angle}deg)`;
      }
    }

    remove() {
      this.isRemoved = true;

      if (this.div) {
        this.div.remove();
        this.div = null;
      }

      this.setMap(null);
    }
  }

