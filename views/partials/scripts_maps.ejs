  // =============================
  // INIT MAP
  // =============================
  function initMap(starting_position = [-6.17045, 106.81595]) {

    if (map) return;

    map = new google.maps.Map(document.getElementById("map"), {
      zoom: 14,
      center: { lat: starting_position[0], lng: starting_position[1] },
      mapTypeId: "roadmap"
    });
  }

  // =============================
  // OPTION DEVICE
  // =============================
  async function setOption(newId, newType) {

    Object.values(markersLayer).forEach(marker => {

      if (!marker) return;

      // marker biasa (kalau ada)
      if (marker.setMap) {
        marker.setMap(null);
      }

      // custom marker
      if (marker.remove) {
        marker.remove();
      }
    });

    markersLayer = {};

    console.log('setOption');
    console.log('deviceid:', newId);
    console.log('type:', newType);

    deviceid = newId;
    type = newType;
  }

  // =============================
  // FETCH GPS API
  // =============================
  async function getLocation() {
    try {

      //console.log('deviceid:', deviceid);
      //console.log('type:', type);

      let result;

      if (type == "all") {

        console.log('getLocation');

        const res = await fetch(`/gps/getMaps`, {
          headers: { Authorization: "Bearer " + token }
        });

        result = await res.json();

      } else if (type == "individu") {

        console.log('getLocation');

        const res = await fetch(`/gps/getDevice/` + deviceid, {
          headers: { Authorization: "Bearer " + token }
        });

        result = await res.json();

      } else if (type == "groups") {

        console.log('getLocation');

        const res = await fetch(`/gps/getMapGroups/` + deviceid, {
          headers: { Authorization: "Bearer " + token }
        });

        result = await res.json();
      }

      const starting_position = result.starting_position;
      const data = result.data;

      //console.log('Data:', data);

      initMap(starting_position);

      updateMarkers(data);

    } catch (err) {

      console.error("getLocation error:", err);

    }
  }

  // =============================
  // UPDATE MARKERS
  // =============================
  function updateMarkers(data) {

    if (!map) return;

    data.forEach(item => {

      const id = item.id;
      const coords = item.coords;
      const popup = item.popup;

      if (!coords || coords.length < 2) return;

      const latLng = {
        lat: parseFloat(coords[0]),
        lng: parseFloat(coords[1])
      };

      // VALIDASI tambahan
      if (isNaN(latLng.lat) || isNaN(latLng.lng)) return;

      if (markersLayer[id]) {

        // =====================
        // HITUNG ROTASI
        // =====================
        if (lastPositions[id]) {
          const last = lastPositions[id];
          const angle = getBearing(last[0], last[1], coords[0], coords[1]);

          markersLayer[id].setRotation(angle); // 🔥 ROTATE REAL
        }

        smoothMoveMarkerCustom(markersLayer[id], latLng);

        // TRAIL
        trails[id].getPath().push(
          new google.maps.LatLng(latLng.lat, latLng.lng)
        );

      } else {

        // MARKER
        markersLayer[id] = new CustomMarker(
          latLng,
          map,
          '/images/Top POV.png',
          popup 
        );

        // INFO WINDOW
        const infowindow = new google.maps.InfoWindow({
          content: popup
        });

        markersLayer[id].addListener("click", () => {
          infowindow.open(map, markersLayer[id]);
        });

        // TRAIL
        trails[id] = new google.maps.Polyline({
          path: [new google.maps.LatLng(latLng.lat, latLng.lng)],
          geodesic: true,
          strokeWeight: 3
        });

        // aktifkan ini jika ingin ada line rute yang di lewati
        //trails[id].setMap(map);
      }

      lastPositions[id] = coords;
    });
  }

  // =============================
  // SMOOTH MOVEMENT
  // =============================
  function smoothMoveMarkerCustom(marker, newLatLng, duration = 1000) {

    if (!marker || !marker.position) return;

    const start = marker.position;

    // ⛑️ HANDLE DUA TIPE
    const startLat = typeof start.lat === "function" ? start.lat() : start.lat;
    const startLng = typeof start.lng === "function" ? start.lng() : start.lng;

    const startTime = performance.now();

    function animate(time) {

      const progress = Math.min((time - startTime) / duration, 1);

      const lat = startLat + (newLatLng.lat - startLat) * progress;
      const lng = startLng + (newLatLng.lng - startLng) * progress;

      marker.updatePosition({ lat, lng });

      if (progress < 1) {
        requestAnimationFrame(animate);
      }
    }

    requestAnimationFrame(animate);
  }

  // =============================
  // HITUNG ARAH KENDARAAN
  // =============================
  function getBearing(lat1, lon1, lat2, lon2) {

    var dLon = (lon2 - lon1) * Math.PI / 180;

    lat1 = lat1 * Math.PI / 180;
    lat2 = lat2 * Math.PI / 180;

    var y = Math.sin(dLon) * Math.cos(lat2);
    var x = Math.cos(lat1) * Math.sin(lat2) -
      Math.sin(lat1) * Math.cos(lat2) * Math.cos(dLon);

    var brng = Math.atan2(y, x);

    brng = brng * 180 / Math.PI;
    brng = (brng + 360) % 360;

    return brng;
  }

  // =============================
  // GPS SIMULATOR
  // =============================
  function simulateGPS() {

    const data = [];

    Object.keys(dummyRoutes).forEach(id => {

      const route = dummyRoutes[id];

      //if (dummyIndex >= route.length) {
      //dummyIndex = route.length - 1; // berhenti di Indomaret
      //}

      if (dummyIndex >= route.length) {
        dummyIndex = 0; // ulang dari awal
      }

      data.push({
        id: id,
        coords: route[dummyIndex],
        popup: "Motor testing dari Permata Bank ke Indomaret"
      });

    });

    dummyIndex++;

    updateMarkers(data);

  }

